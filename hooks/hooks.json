{
  "description": "service-blueprinting plugin hooks: workspace status on session start, IR auto-validation after edits, service-role secret guard before writes. Every script fast-exits in non-blueprint contexts (plugin hooks fire in every session once the plugin is enabled).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session_start_status.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/validate_ir_on_edit.py\"",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/secret_guard.py\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
